# SUPABASE CONFIGURATION
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# BACKEND API URL (Render.com)
# For local development: http://localhost:5000
# For production: Your Render deployment URL (e.g., https://your-app.onrender.com)
VITE_API_URL=http://localhost:5000

# FORMSPREE CONFIGURATION (Optional - for feedback emails)
# Get form endpoint from: https://formspree.io/
# Create a free account and new form, then use the endpoint in src/pages/Feedback.jsx
# Format: https://formspree.io/f/YOUR_FORM_ID

# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual Supabase credentials
# 3. Set VITE_API_URL to your Render backend URL for production
# 4. Never commit .env to git (it's already in .gitignore)
# 5. Add same variables to Vercel for production deployment
